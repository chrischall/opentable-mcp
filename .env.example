# Path to a file containing session cookies exported from an authenticated
# opentable.com Chrome tab. Must include the Akamai cookies (_abck, bm_sz,
# bm_so) plus OpenTable auth cookies (authCke, ha_userSession). Refresh
# every few hours as these expire. Default: ~/.config/opentable-mcp/cookies.txt
OPENTABLE_COOKIES_PATH=/path/to/ot-cookies.txt

# Alternatively, set the cookies directly (takes precedence over the file).
# Handy for MCPB install where the user pastes cookies into a prompt.
# OPENTABLE_COOKIES='otuvid=...; OT-SessionId=...; _abck=...; authCke=...; ha_userSession=...; bm_sz=...; bm_so=...'
